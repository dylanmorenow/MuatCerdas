{
  "name": "muatcerdas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,blue npm:dev:server npm:dev:client",
    "dev:server": "npm run dev -w @muatcerdas/server",
    "dev:client": "npm run dev -w @muatcerdas/client",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:setup": "npm run db:setup -w @muatcerdas/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
