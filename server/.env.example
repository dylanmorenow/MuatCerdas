# Salin ke .env. SQLite dev (file relatif ke prisma/).
DATABASE_URL="file:./dev.db"
PORT=3001

# Auth + peran admin/driver (opsional, Modul D) — default NONAKTIF (demo tanpa login).
# Set AUTH_ENABLED=true untuk mewajibkan login. User (admin + driver) di-seed ke DB;
# kredensial demo ada di README. Set AUTH_SECRET untuk produksi.
AUTH_ENABLED=false
AUTH_SECRET=ubah-rahasia-ini-di-produksi
