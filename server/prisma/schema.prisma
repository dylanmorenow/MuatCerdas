// Skema Prisma — mirror entitas PRD §11 (storage layer).
// Enum direpresentasikan sebagai String (SQLite tak punya enum native); nilai ditegakkan
// oleh Zod di @muatcerdas/shared (schemas.ts). Pemetaan unit (SR-V3) ditegakkan di service/Zod,
// bukan di DB: Unit.category "haul_truck" (ban/Modul A) vs "pit_dumper" (HD785/Modul B).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Unit {
  id             String  @id
  category       String // "haul_truck" | "pit_dumper"
  model          String
  tareKg         Float
  ratedPayloadKg Float
  tiresCount     Int
  tireModel      String?
  tirePriceIdr   Float?
  kmPerYear      Float?
  material       String? // HD785: "coal" | "overburden" (Modul B/Dashboard quota); null utk haul
  zone           String? // zona operasi truk hauling (ADMIN-8): "cpp" | "tengah" | "jetty"

  tireRecords   TireRecord[]
  tripLogs      TripLog[]
  payloadEvents PayloadEvent[]
  calibrations  CalibrationRecord[]
  massInputs    MassInput[]
  driverEvents  DriverEvent[]
}

model Operator {
  id    String @id
  name  String
  shift String // "day" | "night"

  tripLogs      TripLog[]
  payloadEvents PayloadEvent[]
}

model RoadSegment {
  id                String @id
  name              String
  surface           String // "laterite" | "rock" | "sealed"
  lengthKm          Float
  conditionScore    Float // 0..1
  avgSpeedLoadedKmh Float
  avgSpeedEmptyKmh  Float

  exposures TripSegmentExposure[]
  hazards   RoadHazard[]
}

// Registry ban truk hauling (Modul A).
model TireRecord {
  id                      String    @id
  unitId                  String
  position                String
  installDate             DateTime
  removalDate             DateTime?
  kmAtRemoval             Float?
  avgPressureDeviationPct Float?
  loadIndex               Float?
  removalReason           String // "worn" | "cut" | "overload" | "scheduled"
  costIdr                 Float

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId])
}

// Log perjalanan truk hauling (Modul A).
model TripLog {
  id                      String   @id
  unitId                  String
  operatorId              String
  date                    DateTime
  km                      Float
  avgPressureDeviationPct Float?
  payloadIdx              Float?

  unit            Unit                  @relation(fields: [unitId], references: [id])
  operator        Operator              @relation(fields: [operatorId], references: [id])
  segmentExposure TripSegmentExposure[]

  @@index([unitId])
  @@index([operatorId])
}

// Anak relasional dari TripLog.segmentExposure (PRD §11) — queryable untuk §12.1.
model TripSegmentExposure {
  id        String @id @default(cuid())
  tripLogId String
  segmentId String
  km        Float

  tripLog TripLog     @relation(fields: [tripLogId], references: [id], onDelete: Cascade)
  segment RoadSegment @relation(fields: [segmentId], references: [id])

  @@index([tripLogId])
  @@index([segmentId])
}

// Event payload HD785 (Modul B).
model PayloadEvent {
  id                String   @id
  unitId            String
  operatorId        String
  timestamp         DateTime
  measuredPayloadKg Float
  targetPayloadKg   Float
  status            String // "under" | "ok" | "over"

  unit     Unit     @relation(fields: [unitId], references: [id])
  operator Operator @relation(fields: [operatorId], references: [id])

  @@index([unitId])
  @@index([operatorId])
}

model CalibrationRecord {
  id                  String   @id @default(cuid())
  unitId              String
  lastCalibrationDate DateTime
  scaleStudyOffsetPct Float

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId])
}

// Settings baris-tunggal — CostParams (PRD §12). Editable di UI (M6); selalu id = 1.
model CostParams {
  id                        Int   @id @default(1)
  tirePriceIdr              Float
  tiresPerUnit              Float
  kmPerYear                 Float
  tireLifeActualKm          Float
  tireLifeBestKm            Float
  captureRate               Float
  fleetSize                 Int
  capexIdr                  Float
  opexAnnualIdr             Float
  fuelCostPerTripIdr        Float
  tripsPerYear              Float
  underloadPct              Float
  overloadWearCostFactorIdr Float
}

// Settings baris-tunggal — SpeedParams Modul C (docs/MODULE_C_SPEED.md §C). Editable di UI (M9);
// selalu id = 1. TERPISAH dari CostParams agar sanity Modul A/B tak tersentuh.
model SpeedParams {
  id                       Int   @id @default(1)
  tempCorrectionFactor     Float
  siteCorrectionFactor     Float
  loadShareHeaviestPosition Float
  distancePerShiftKm       Float
  workHoursPerShift        Float
  effectiveWorkHoursPerDay Float
  fixedTimeHours           Float
  oneWayKm                 Float
  dailyTargetTon           Float
}

// Katalog TKPH per model ban (§C.2). Nilai WAJIB DICARI dari brosur pabrik. Editable (FR-0003-1).
model TkphCatalog {
  tireModel   String @id
  catalogTkph Float
}

// Modul D (M10) — pengguna & peran. Tipis: admin (akses penuh) / driver (satu unit).
// password = kredensial DEMO (plain, didokumentasikan di README) — bukan manajemen user/RBAC kompleks.
model User {
  id       String  @id @default(cuid())
  username String  @unique
  password String
  role     String // "admin" | "driver"
  name     String
  shift    String? // driver
  unitId   String? // unit yang dikemudikan (driver)
}

// Parameter operasional (Dashboard reframe — kerugian/risiko). Settings id=1. ASUMSI baru,
// TERPISAH dari CostParams agar sanity finansial §8 tak tersentuh.
model OpsParams {
  id                             Int   @id @default(1)
  downtimeDaysPerCriticalUnit    Float
  productionValuePerUnitPerDayIdr Float
  dailyCoalTargetT               Float
}

// Modul revisi F2 — laporan massa muatan oleh operator lapangan (store-and-forward).
// HD785: operator driver mencatat massa + material + nama operator excavator pemuat.
// Truk hauling: operator mencatat massa per bucket (umumnya 2 bucket), material = coal.
// SUMBER: input operator (disimulasikan; antrean offline di klien). Adaptor operatorFeed
// menyiapkan batas integrasi feed nyata — bukan perangkat live di kabin.
model MassInput {
  id               String   @id @default(cuid())
  unitId           String
  category         String // "pit_dumper" | "haul_truck" (disimpan utk query cepat; ditegakkan vs Unit)
  material         String? // "coal" | "overburden"
  totalT           Float
  bucket1T         Float? // truk hauling (bucket 1)
  bucket2T         Float? // truk hauling (bucket 2)
  excavatorOperator String? // HD785: nama operator excavator pemuat
  operatorName     String // operator pelapor (driver)
  timestamp        DateTime @default(now())
  source           String   @default("operator") // "operator" | "import" | "feed" (operatorFeed adaptor)

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId])
  @@index([timestamp])
}

// Revisi F3 + akhir — bahaya jalan dari "kamera berbasis AI" (SIMULASI; truk pemeta = hauling
// lead/last). conditionScore segmen diturunkan dari kumpulan bahaya ini (shared/hazard.ts) →
// menyetir Modul A/C. Batas integrasi: adaptor roadMapSource bisa menyambung feed kamera nyata.
model RoadHazard {
  id         String   @id @default(cuid())
  type       String // pothole|rutting|washboard|sharp_rock|spillage|standing_water|mud|edge_break
  segmentId  String
  positionKm Float // posisi sepanjang rute CPP KM33 → Jetty (0..~35)
  severity   Float // 0..1
  coveragePct Float  @default(0) // perkiraan lebar jalan yang tertutup bahaya (0..1)
  urgent     Boolean @default(false) // perlu tindakan segera (menutupi jalan / tak terhindarkan)
  detectedAt DateTime @default(now())
  source     String   @default("camera_ai")

  segment RoadSegment @relation(fields: [segmentId], references: [id])

  @@index([segmentId])
}

// Revisi F3 — kejadian per unit dari surface driver (SIMULASI): overspeed (vs Vmax_safe) &
// melewati zona bahaya. Dikonsumsi rekomendasi Modul A. Masuk via antrean offline operator.
model DriverEvent {
  id        String   @id @default(cuid())
  unitId    String
  type      String // "overspeed" | "hazard" | "hard_braking"
  detail    String
  atKm      Float?
  hazardType String?
  timestamp DateTime @default(now())
  source    String   @default("sim")

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId])
  @@index([timestamp])
}

// Revisi akhir (OPERATOR-2) — katalog operator excavator (nama + tipe) untuk dropdown laporan
// HD785. Bisa ditambah operator/anggota baru; tersimpan dan otomatis muncul di pilihan berikutnya.
model ExcavatorOperator {
  id            String  @id @default(cuid())
  name          String  @unique
  excavatorType String // "PC2000" | "PC1250" | "PC850" | dst
}

// Revisi akhir (ADMIN-5) — tindakan yang sudah diselesaikan (ganti ban, rekomendasi, kalibrasi).
// Item yang ditandai selesai dikecualikan dari daftar & total biaya/kerugian. Tersimpan permanen.
model ResolvedAction {
  id         String   @id @default(cuid())
  unitId     String
  actionType String // "tire_replace" | "recommendation" | "calibration"
  refKey     String // kunci unik tindakan (mis. unitId+factor) agar idempoten
  detail     String?
  resolvedAt DateTime @default(now())

  @@unique([actionType, refKey])
  @@index([unitId])
}

// Revisi akhir (ADMIN-8) — kondisi jalan per zona operasi. Memengaruhi kecepatan aman unit di
// zona itu (selain muatan). Settings: satu baris per zona.
model ZoneCondition {
  zone      String @id // "cpp" | "tengah" | "jetty"
  condition String // "normal" | "dusty" | "wet" | "muddy" | "slippery"
}
