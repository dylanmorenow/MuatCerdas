{
  "name": "@muatcerdas/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:setup": "prisma migrate dev --name init && prisma generate && tsx src/seed.ts",
    "db:seed": "tsx src/seed.ts",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^10.0.0",
    "@muatcerdas/shared": "*",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.0",
    "papaparse": "^5.5.3",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.5.2",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2"
  }
}
